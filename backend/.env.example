# ── Local dev (SQLite, zero setup) ──────────────────────────────────────────
DATABASE_URL=sqlite:///./andatest.db

# ── Production: Neon PostgreSQL ──────────────────────────────────────────────
# 1. Create a free project at neon.tech
# 2. Copy the connection string from the Neon dashboard (Connection Details)
# 3. Replace the value below — use the "pooled" connection string for production
# DATABASE_URL=postgresql+psycopg2://user:pass@ep-xxx.eu-central-1.aws.neon.tech/andatest?sslmode=require

SECRET_KEY=change-me-in-production-use-a-long-random-string

# Comma-separated allowed origins for CORS
# Local dev:
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:5500,http://localhost:8502
# Production: add your Render URL
# CORS_ORIGINS=https://andatest-api.onrender.com
